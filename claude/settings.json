{
  "attribution": {
    "commit": "",
    "pr": ""
  },
  "permissions": {
    "allow": [
      "Bash(*)",
      "Read(//private/tmp/**)",
      "Read(//tmp/**)",
      "Read(//Users/Craig/Developer/**)",
      "Read(//Users/Craig/.claude/**)",
      "Edit(//Users/Craig/Developer/**)",
      "WebFetch(*)",
      "WebSearch(*)",
      "Skill(*)"
    ],
    "deny": [
      "Bash(terraform apply)",
      "Bash(terraform apply *)",
      "Bash(terraform destroy)",
      "Bash(terraform destroy *)",
      "Bash(terraform import)",
      "Bash(terraform import *)",
      "Bash(npm *)",
      "Bash(npx *)",
      "Bash(cargo publish)",
      "Bash(cargo publish *)",
      "Bash(rm *)",
      "Bash(rmdir *)",
      "Bash(aws * create-*)",
      "Bash(aws * delete-*)",
      "Bash(aws * put-*)",
      "Bash(aws * update-*)",
      "Bash(aws * terminate-*)",
      "Bash(aws * modify-*)",
      "Bash(aws s3 cp *)",
      "Bash(aws s3 mv *)",
      "Bash(aws s3 rm *)",
      "Bash(aws s3 sync *)"
    ],
    "defaultMode": "plan"
  },
  "model": "opus[1m]",
  "effortLevel": "xhigh",
  "hooks": {
    "PostToolUse": [
      {
        "matcher": "Edit|Write",
        "hooks": [
          {
            "type": "command",
            "command": "\"${HOME}\"/.claude/hooks/format.sh"
          },
          {
            "type": "command",
            "command": "\"${HOME}\"/.claude/hooks/docs.sh"
          }
        ]
      }
    ],
    "Stop": [
      {
        "hooks": [
          {
            "type": "command",
            "command": "\"${HOME}\"/.claude/hooks/lint.sh"
          }
        ]
      }
    ]
  },
  "statusLine": {
    "type": "command",
    "command": "\"${HOME}\"/.claude/statusline-command.sh"
  },
  "voice": {
    "enabled": true
  },
  "spinnerTipsEnabled": false
}
