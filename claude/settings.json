{
  "permissions": {
    "allow": [
      "Bash(git status)",
      "Bash(git log *)",
      "Bash(git diff *)",
      "Bash(git branch *)",
      "Bash(git show *)",
      "Bash(git -C * status)",
      "Bash(git -C * log *)",
      "Bash(git -C * diff *)",
      "Bash(git -C * branch *)",
      "Bash(git -C * show *)",
      "Bash(make *)",
      "Bash(man *)",
      "Bash(which *)",
      "Bash(uname *)",
      "Bash(echo *)",
      "Bash(cat *)",
      "Bash(head *)",
      "Bash(tail *)",
      "Bash(wc *)",
      "Bash(ls *)",
      "Bash(ls * | head *)",
      "Bash(ls * | tail *)",
      "Bash(ls * | grep *)",
      "Bash(ls * | wc *)",
      "Bash(ls * | sort *)",
      "Bash(find *)",
      "Bash(find * | head *)",
      "Bash(find * | tail *)",
      "Bash(find * | grep *)",
      "Bash(find * | wc *)",
      "Bash(find * | sort *)",
      "Bash(find * | uniq *)",
      "Bash(find * | xargs grep *)",
      "Bash(find * | xargs rg *)",
      "Bash(find * | xargs wc *)",
      "Bash(find * | xargs head *)",
      "Bash(find * | xargs cat *)",
      "Bash(grep *)",
      "Bash(rg *)",
      "Bash(fd *)",
      "Bash(sort *)",
      "Bash(uniq *)",
      "Bash(tr *)",
      "Bash(cut *)",
      "Bash(awk *)",
      "Bash(sed *)",
      "Bash(env)",
      "Bash(printenv *)",
      "Bash(type *)",
      "Bash(file *)",
      "Bash(stat *)",
      "Bash(date *)",
      "Bash(pwd)",
      "Bash(go build *)",
      "Bash(go test *)",
      "Bash(go vet *)",
      "Bash(go fix *)",
      "Bash(go mod *)",
      "Bash(go fmt *)",
      "Bash(go doc *)",
      "Bash(go list *)",
      "Bash(go version *)",
      "Bash(go env *)",
      "Bash(govulncheck *)",
      "Bash(terraform init *)",
      "Bash(terraform plan *)",
      "Bash(yamllint *)",
      "Bash(tflint *)",
      "Bash(terraform validate *)",
      "Bash(terraform fmt *)",
      "Bash(terraform show *)",
      "Bash(terraform state list *)",
      "Bash(terraform state show *)",
      "Bash(terraform output *)",
      "Bash(terraform providers *)",
      "Bash(terraform version *)",
      "Bash(gh auth status)",
      "Bash(gh config list)",
      "Bash(gh pr view *)",
      "Bash(gh pr list *)",
      "Bash(gh pr checks *)",
      "Bash(gh pr status)",
      "Bash(gh issue view *)",
      "Bash(gh issue list *)",
      "Bash(gh issue status)",
      "Bash(gh run view *)",
      "Bash(gh run list *)",
      "Bash(gh repo view *)",
      "Bash(gh search *)",
      "Bash(gh pr diff *)",
      "Bash(gh release view *)",
      "Bash(gh release list *)",
      "Bash(gh workflow view *)",
      "Bash(gh workflow list *)",
      "Bash(gh label list *)",
      "Bash(gh api -X GET *)",
      "WebFetch(*)",
      "WebSearch(*)",
      "Skill(fix-github-issue:*)",
      "Skill(review-pr:*)"
    ],
    "defaultMode": "plan"
  },
  "model": "claude-opus-4-6[1m]",
  "effortLevel": "high",
  "includeCoAuthoredBy": false,
  "enabledPlugins": {
    "gopls-lsp@claude-plugins-official": true
  },
  "statusLine": {
    "type": "command",
    "command": "\"${HOME}/.claude/statusline-command.sh\""
  },
  "enableRemoteControl": true,
  "terminalNotifications": false,
  "hooks": {
    "SessionEnd": [
      {
        "matcher": "",
        "hooks": [
          {
            "type": "command",
            "command": "\"${HOME}/.claude/hooks/session-context.sh\""
          }
        ]
      }
    ],
    "PostToolUse": [
      {
        "matcher": "Edit|Write|MultiEdit",
        "hooks": [
          {
            "type": "command",
            "command": "\"${HOME}/.claude/hooks/format.sh\""
          }
        ]
      },
      {
        "matcher": "Edit|Write|MultiEdit",
        "hooks": [
          {
            "type": "command",
            "command": "\"${HOME}/.claude/hooks/go-fmt.sh\""
          }
        ]
      },
      {
        "matcher": "Edit|Write|MultiEdit",
        "hooks": [
          {
            "type": "command",
            "command": "\"${HOME}/.claude/hooks/go-lint.sh\""
          }
        ]
      },
      {
        "matcher": "Edit|Write|MultiEdit",
        "hooks": [
          {
            "type": "command",
            "command": "\"${HOME}/.claude/hooks/terraform-docs.sh\""
          }
        ]
      }
    ],
    "Stop": [
      {
        "matcher": "",
        "hooks": [
          {
            "type": "command",
            "command": "\"${HOME}/.claude/hooks/go-fix.sh\""
          }
        ]
      },
      {
        "matcher": "",
        "hooks": [
          {
            "type": "command",
            "command": "\"${HOME}/.claude/hooks/shell-lint.sh\""
          }
        ]
      },
      {
        "matcher": "",
        "hooks": [
          {
            "type": "command",
            "command": "\"${HOME}/.claude/hooks/turn-context.sh\""
          }
        ]
      }
    ]
  }
}
