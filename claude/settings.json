{
  "permissions": {
    "allow": [
      "Bash(git status)",
      "Bash(git log *)",
      "Bash(git diff *)",
      "Bash(git branch *)",
      "Bash(git show *)",
      "Bash(make *)",
      "Bash(man *)",
      "Bash(which *)",
      "Bash(uname *)",
      "Bash(echo *)",
      "Bash(cat *)",
      "Bash(head *)",
      "Bash(tail *)",
      "Bash(wc *)",
      "Bash(ls *)",
      "Bash(find *)",
      "Bash(grep *)",
      "Bash(rg *)",
      "Bash(fd *)",
      "Bash(sort *)",
      "Bash(uniq *)",
      "Bash(tr *)",
      "Bash(cut *)",
      "Bash(awk *)",
      "Bash(sed *)",
      "Bash(env)",
      "Bash(printenv *)",
      "Bash(type *)",
      "Bash(file *)",
      "Bash(stat *)",
      "Bash(date *)",
      "Bash(pwd)",
      "Bash(go *)",
      "Bash(terraform *)",
      "Bash(gh pr view *)",
      "Bash(gh pr list *)",
      "Bash(gh pr checks *)",
      "Bash(gh pr status)",
      "Bash(gh issue view *)",
      "Bash(gh issue list *)",
      "Bash(gh issue status)",
      "Bash(gh run view *)",
      "Bash(gh run list *)",
      "Bash(gh repo view *)",
      "Bash(gh search *)",
      "Bash(gh pr diff *)",
      "Bash(gh release view *)",
      "Bash(gh release list *)",
      "Bash(gh workflow view *)",
      "Bash(gh workflow list *)",
      "Bash(gh label list *)",
      "Bash(gh api *)",
      "WebFetch(*)",
      "WebSearch(*)",
      "Skill(fix-github-issue:*)",
      "Skill(review-pr:*)"
    ],
    "defaultMode": "plan"
  },
  "model": "claude-opus-4-6[1m]",
  "effortLevel": "high",
  "includeCoAuthoredBy": false,
  "enabledPlugins": {
    "gopls-lsp@claude-plugins-official": true
  },
  "statusLine": {
    "type": "command",
    "command": "\"${HOME}/.claude/statusline-command.sh\""
  },
  "enableRemoteControl": true,
  "terminalNotifications": false,
  "hooks": {
    "SessionEnd": [
      {
        "matcher": "",
        "hooks": [
          {
            "type": "command",
            "command": "\"${HOME}/.claude/hooks/session-context.sh\""
          }
        ]
      }
    ],
    "PostToolUse": [
      {
        "matcher": "Edit|Write|MultiEdit",
        "hooks": [
          {
            "type": "command",
            "command": "\"${HOME}/.claude/hooks/format.sh\""
          }
        ]
      },
      {
        "matcher": "Edit|Write|MultiEdit",
        "hooks": [
          {
            "type": "command",
            "command": "\"${HOME}/.claude/hooks/go-fmt.sh\""
          }
        ]
      }
    ],
    "Stop": [
      {
        "matcher": "",
        "hooks": [
          {
            "type": "command",
            "command": "\"${HOME}/.claude/hooks/go-fix.sh\""
          }
        ]
      }
    ]
  }
}
