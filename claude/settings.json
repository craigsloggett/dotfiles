{
  "attribution": {
    "commit": "",
    "pr": ""
  },
  "permissions": {
    "allow": [
      "Bash(*)",
      "Read(//private/tmp/**)",
      "Read(//tmp/**)",
      "Read(//Users/Craig/Developer/**)",
      "Read(//Users/Craig/.claude/**)",
      "WebFetch(*)",
      "WebSearch(*)",
      "Skill(*)"
    ],
    "deny": [
      "Bash(terraform apply)",
      "Bash(terraform apply *)",
      "Bash(terraform destroy)",
      "Bash(terraform destroy *)",
      "Bash(terraform import)",
      "Bash(terraform import *)",
      "Bash(npm *)",
      "Bash(npx *)",
      "Bash(cargo publish)",
      "Bash(cargo publish *)",
      "Bash(rm *)",
      "Bash(rmdir *)",
      "Bash(aws * create-*)",
      "Bash(aws * delete-*)",
      "Bash(aws * put-*)",
      "Bash(aws * update-*)",
      "Bash(aws * terminate-*)",
      "Bash(aws * modify-*)",
      "Bash(aws s3 cp *)",
      "Bash(aws s3 mv *)",
      "Bash(aws s3 rm *)",
      "Bash(aws s3 sync *)"
    ],
    "defaultMode": "plan"
  },
  "model": "opus[1m]",
  "effortLevel": "high",
  "hooks": {
    "SessionEnd": [
      {
        "matcher": "",
        "hooks": [
          {
            "type": "command",
            "command": "\"${HOME}/.claude/hooks/session-context.sh\""
          }
        ]
      }
    ],
    "PostToolUse": [
      {
        "matcher": "Edit|Write|MultiEdit",
        "hooks": [
          {
            "type": "command",
            "command": "\"${HOME}/.claude/hooks/format.sh\""
          }
        ]
      },
      {
        "matcher": "Edit|Write|MultiEdit",
        "hooks": [
          {
            "type": "command",
            "command": "\"${HOME}/.claude/hooks/docs.sh\""
          }
        ]
      }
    ],
    "Stop": [
      {
        "matcher": "",
        "hooks": [
          {
            "type": "command",
            "command": "\"${HOME}/.claude/hooks/lint.sh\""
          }
        ]
      },
      {
        "matcher": "",
        "hooks": [
          {
            "type": "command",
            "command": "\"${HOME}/.claude/hooks/turn-context.sh\""
          }
        ]
      }
    ]
  },
  "statusLine": {
    "type": "command",
    "command": "\"${HOME}/.claude/statusline-command.sh\""
  },
  "enabledPlugins": {
    "gopls-lsp@claude-plugins-official": true,
    "lua-lsp@claude-plugins-official": true
  },
  "spinnerTipsEnabled": false,
  "voiceEnabled": true,
  "prefersReducedMotion": true
}
